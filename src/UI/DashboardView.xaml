<UserControl x:Class="ActivityDashboard.UI.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:ActivityDashboard.UI"
             Background="Transparent"
             TextOptions.TextFormattingMode="Display">
    <UserControl.Resources>
        <local:DurationToTextConverter x:Key="DurationToTextConverter" />
        <local:HeatmapHeightConverter x:Key="HeatmapHeightConverter" />
        <local:HeatmapWidthConverter x:Key="HeatmapWidthConverter" />
        <local:DistributionFillConverter x:Key="DistributionFillConverter" />
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <DropShadowEffect x:Key="PanelShadow" BlurRadius="18" ShadowDepth="5" Opacity="0.32" Color="#000000" />

        <Style x:Key="SectionSurface" TargetType="Border">
            <Setter Property="Background" Value="#E9161B2A" />
            <Setter Property="BorderBrush" Value="#2742506B" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Padding" Value="22" />
            <Setter Property="Effect" Value="{StaticResource PanelShadow}" />
        </Style>

        <Style x:Key="MetricCard" TargetType="Border">
            <Setter Property="Background" Value="#E91B2132" />
            <Setter Property="BorderBrush" Value="#36505C75" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="14,12" />
            <Setter Property="MinWidth" Value="190" />
            <Setter Property="Margin" Value="0,0,14,14" />
            <Setter Property="Effect" Value="{StaticResource PanelShadow}" />
        </Style>

        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FFF7FAFF" />
            <Setter Property="FontSize" Value="17" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="RefreshButton" TargetType="Button">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="#3B68E6C6" />
            <Setter Property="BorderBrush" Value="#856EE7D2" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="18,10" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Surface" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="9">
                            <ContentPresenter Margin="{TemplateBinding Padding}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Surface" Property="Background" Value="#5A75F2D9" /></Trigger>
                            <Trigger Property="IsPressed" Value="True"><Setter TargetName="Surface" Property="Background" Value="#2F4FC1A7" /></Trigger>
                            <Trigger Property="IsEnabled" Value="False"><Setter TargetName="Surface" Property="Opacity" Value="0.45" /></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="QuickStatCard" TargetType="Border">
            <Setter Property="Background" Value="#1F1B2236" />
            <Setter Property="BorderBrush" Value="#33465778" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="Margin" Value="0,0,8,0" />
        </Style>

        <Style x:Key="SectionTab" TargetType="Button">
            <Setter Property="Foreground" Value="#FFC9D5EC" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="18,10" />
            <Setter Property="Margin" Value="0,0,4,0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Surface" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="0" CornerRadius="10" Padding="{TemplateBinding Padding}">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock x:Name="Glyph" Text="{TemplateBinding Tag}" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center" Foreground="{TemplateBinding Foreground}" />
                                <ContentPresenter VerticalAlignment="Center" />
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Surface" Property="Background" Value="#1A2A344B" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RankRow" TargetType="Border">
            <Setter Property="Background" Value="#521E2638" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="9,8" />
            <Setter Property="Margin" Value="0,0,0,7" />
        </Style>

        <Style x:Key="RankingProgress" TargetType="ProgressBar">
            <Setter Property="Height" Value="4" />
            <Setter Property="Maximum" Value="100" />
            <Setter Property="Background" Value="#FF293248" />
            <Setter Property="Foreground" Value="#FF7697F7" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Grid ClipToBounds="True">
                            <Border Background="{TemplateBinding Background}" CornerRadius="2" />
                            <Border x:Name="PART_Indicator" Background="{TemplateBinding Foreground}" CornerRadius="2" HorizontalAlignment="Left" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DistributionProgress" TargetType="ProgressBar">
            <Setter Property="Height" Value="6" />
            <Setter Property="Maximum" Value="100" />
            <Setter Property="Background" Value="#FF293248" />
            <Setter Property="Foreground" Value="#FF6D83F5" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Grid ClipToBounds="True">
                            <Border Background="{TemplateBinding Background}" CornerRadius="3" />
                            <Border x:Name="PART_Indicator" Background="{TemplateBinding Foreground}" CornerRadius="3" HorizontalAlignment="Left" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PeriodPickerItem" TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="#FFDCE5F5" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="12,9" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemSurface" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}" Margin="3,2">
                            <ContentPresenter VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True"><Setter TargetName="ItemSurface" Property="Background" Value="#FF303D59" /><Setter Property="Foreground" Value="#FFFFFFFF" /></Trigger>
                            <Trigger Property="IsSelected" Value="True"><Setter TargetName="ItemSurface" Property="Background" Value="#FF34476D" /><Setter Property="Foreground" Value="#FFC9D7FF" /></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PeriodPicker" TargetType="ComboBox">
            <Setter Property="Foreground" Value="#FFF2F6FF" />
            <Setter Property="Background" Value="#FF20283A" />
            <Setter Property="BorderBrush" Value="#FF465875" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="MinWidth" Value="176" />
            <Setter Property="Height" Value="36" />
            <Setter Property="ItemContainerStyle" Value="{StaticResource PeriodPickerItem}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="PickerButton" Focusable="False" ClickMode="Press" Foreground="#FFF2F6FF" IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="PickerSurface" Background="#FF20283A" BorderBrush="#FF465875" BorderThickness="1" CornerRadius="8">
                                            <Grid Margin="12,0,10,0">
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="22" /></Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding SelectedPlaytimePeriod.Name}" Foreground="#FFF2F6FF" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                                <TextBlock Grid.Column="1" Text="&#x2304;" Foreground="#FF91A4C2" FontSize="15" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,-3,0,0" />
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="PickerSurface" Property="Background" Value="#FF29344B" /><Setter TargetName="PickerSurface" Property="BorderBrush" Value="#FF647A9F" /></Trigger>
                                            <Trigger Property="IsChecked" Value="True"><Setter TargetName="PickerSurface" Property="Background" Value="#FF29344B" /><Setter TargetName="PickerSurface" Property="BorderBrush" Value="#FF7895C8" /></Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <Popup x:Name="PART_Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}" AllowsTransparency="True" Focusable="False" PopupAnimation="Fade">
                                <Grid MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}" Margin="0,5,0,0">
                                    <Border Background="#FF171E2D" BorderBrush="#FF465875" BorderThickness="1" CornerRadius="9" Padding="3" Effect="{StaticResource PanelShadow}">
                                        <ScrollViewer MaxHeight="260" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                            <ItemsPresenter />
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="HasItems" Value="False"><Setter TargetName="PART_Popup" Property="MinHeight" Value="36" /></Trigger>
                            <Trigger Property="IsEnabled" Value="False"><Setter TargetName="PickerButton" Property="Opacity" Value="0.45" /></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#FF080C1B" Offset="0" />
                <GradientStop Color="#FF11142A" Offset="0.48" />
                <GradientStop Color="#FF090D1D" Offset="1" />
            </LinearGradientBrush>
        </Grid.Background>
        <Ellipse Width="680" Height="520" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="-210,-270,0,0" IsHitTestVisible="False" Opacity="0.22">
            <Ellipse.Fill><RadialGradientBrush><GradientStop Color="#FF6657E8" Offset="0" /><GradientStop Color="#006657E8" Offset="1" /></RadialGradientBrush></Ellipse.Fill>
        </Ellipse>
        <Ellipse Width="620" Height="400" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-220,-160,0" IsHitTestVisible="False" Opacity="0.14">
            <Ellipse.Fill><RadialGradientBrush><GradientStop Color="#FF2BC5A3" Offset="0" /><GradientStop Color="#002BC5A3" Offset="1" /></RadialGradientBrush></Ellipse.Fill>
        </Ellipse>
        <Ellipse Width="540" Height="540" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-220,160" IsHitTestVisible="False" Opacity="0.12">
            <Ellipse.Fill><RadialGradientBrush><GradientStop Color="#FFE06BC6" Offset="0" /><GradientStop Color="#00E06BC6" Offset="1" /></RadialGradientBrush></Ellipse.Fill>
        </Ellipse>

        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" PanningMode="VerticalOnly">
            <StackPanel Margin="36,18,36,32">
                <!-- Persistent quick stats bar -->
                <Border Background="#1A0F1626" BorderBrush="#222E3D5C" BorderThickness="1" CornerRadius="12" Padding="12,10" Margin="0,0,0,10">
                    <Grid>
                        <UniformGrid Rows="1" Columns="6">
                            <Border Style="{StaticResource QuickStatCard}">
                                <StackPanel>
                                    <TextBlock Text="STREAK" Foreground="#FFA5B5D2" FontSize="9" FontWeight="Bold" />
                                    <TextBlock Text="{Binding CurrentStreakText}" Foreground="#FFFFD79C" FontSize="17" FontWeight="SemiBold" Margin="0,4,0,0" />
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource QuickStatCard}">
                                <StackPanel>
                                    <TextBlock Text="TRACKED TIME" Foreground="#FFA5B5D2" FontSize="9" FontWeight="Bold" />
                                    <TextBlock Text="{Binding TrackedPlaytime}" Foreground="#FF8DDFC8" FontSize="17" FontWeight="SemiBold" Margin="0,4,0,0" />
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource QuickStatCard}">
                                <StackPanel>
                                    <TextBlock Text="SESSIONS" Foreground="#FFA5B5D2" FontSize="9" FontWeight="Bold" />
                                    <TextBlock Text="{Binding TotalSessionsText}" Foreground="#FFAFBFFF" FontSize="17" FontWeight="SemiBold" Margin="0,4,0,0" />
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource QuickStatCard}">
                                <StackPanel>
                                    <TextBlock Text="AVG SESSION" Foreground="#FFA5B5D2" FontSize="9" FontWeight="Bold" />
                                    <TextBlock Text="{Binding AverageSessionText}" Foreground="#FFFFD79C" FontSize="17" FontWeight="SemiBold" Margin="0,4,0,0" />
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource QuickStatCard}">
                                <StackPanel>
                                    <TextBlock Text="ACTIVE DAYS" Foreground="#FFA5B5D2" FontSize="9" FontWeight="Bold" />
                                    <TextBlock Text="{Binding ActiveDaysText}" Foreground="#FFAFBFFF" FontSize="17" FontWeight="SemiBold" Margin="0,4,0,0" />
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource QuickStatCard}" Margin="0">
                                <StackPanel>
                                    <TextBlock Text="TOP DAY" Foreground="#FFA5B5D2" FontSize="9" FontWeight="Bold" />
                                    <TextBlock Text="{Binding MostActiveDay}" Foreground="#FFE4B7D4" FontSize="17" FontWeight="SemiBold" Margin="0,4,0,0" TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </Border>
                        </UniformGrid>
                        <Button Style="{StaticResource RefreshButton}" Click="Refresh_Click" HorizontalAlignment="Right" VerticalAlignment="Center" Padding="14,8" Margin="0,0,4,0">
                            <StackPanel Orientation="Horizontal"><TextBlock Text="↻" FontSize="14" Margin="0,-1,6,0" /><TextBlock Text="Refresh" FontWeight="SemiBold" FontSize="12" /></StackPanel>
                        </Button>
                    </Grid>
                </Border>

                <!-- Section tabs -->
                <Border Background="#1A0F1626" BorderBrush="#222E3D5C" BorderThickness="1" CornerRadius="12" Padding="8,6" Margin="0,0,0,14">
                    <StackPanel Orientation="Horizontal">
                        <Button x:Name="OverviewTab" Click="SelectOverview" Tag="&#x25A6;">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SectionTab}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsOverviewSelected}" Value="True">
                                            <Setter Property="Background" Value="#FF2A344B" />
                                            <Setter Property="Foreground" Value="#FFFFFFFF" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <TextBlock Text="Overview" />
                        </Button>
                        <Button x:Name="ActivityTab" Click="SelectActivity" Tag="&#x2630;">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SectionTab}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsActivitySelected}" Value="True">
                                            <Setter Property="Background" Value="#FF2A344B" />
                                            <Setter Property="Foreground" Value="#FFFFFFFF" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <TextBlock Text="Activity" />
                        </Button>
                        <Button x:Name="LibraryTab" Click="SelectLibrary" Tag="&#x25C7;">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SectionTab}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsLibrarySelected}" Value="True">
                                            <Setter Property="Background" Value="#FF2A344B" />
                                            <Setter Property="Foreground" Value="#FFFFFFFF" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <TextBlock Text="Library" />
                        </Button>
                        <Button x:Name="SessionsTab" Click="SelectSessions" Tag="&#x29C9;">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SectionTab}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSessionsSelected}" Value="True">
                                            <Setter Property="Background" Value="#FF2A344B" />
                                            <Setter Property="Foreground" Value="#FFFFFFFF" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <TextBlock Text="Sessions" />
                        </Button>
                    </StackPanel>
                </Border>

                <TextBlock Text="Loading Playnite data..." Foreground="#FF9DF1D5" Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}" Margin="4,0,0,8" />
                <TextBlock Text="{Binding ErrorMessage}" Foreground="#FFFF9C9C" TextWrapping="Wrap" Margin="4,0,0,8" />

                <!-- ====================== OVERVIEW TAB ====================== -->
                <StackPanel Visibility="{Binding IsOverviewSelected, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <!-- Last session header -->
                    <Border CornerRadius="14" BorderBrush="#3A6D75A5" BorderThickness="1" Margin="0,0,0,18" Padding="18,12" Effect="{StaticResource PanelShadow}">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#ED1F2942" Offset="0" />
                                <GradientStop Color="#E91A2548" Offset="0.55" />
                                <GradientStop Color="#E92A1F3E" Offset="1" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Border Width="56" Height="76" CornerRadius="7" ClipToBounds="True" Background="#FF252D3F">
                                <Image Source="{Binding LastSession.CoverPath}" Stretch="UniformToFill" />
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="16,0,16,0">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                    <Border Background="#2F77E9D4" CornerRadius="4" Padding="8,3" Margin="0,0,8,0"><TextBlock Text="LAST SESSION" FontWeight="Bold" FontSize="10" Foreground="#FFE2FFFA" /></Border>
                                    <TextBlock Text="{Binding LastSessionWhen}" Foreground="#FFA5B5D2" FontWeight="SemiBold" FontSize="11" VerticalAlignment="Center" />
                                </StackPanel>
                                <TextBlock Text="{Binding LastSessionGame}" Foreground="#FFF9FBFF" FontSize="19" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                            <Border Grid.Column="2" Background="#1A2A344B" BorderBrush="#3FE9A34D" BorderThickness="1" CornerRadius="9" Padding="12,7" VerticalAlignment="Center">
                                <StackPanel>
                                    <TextBlock Text="DURATION" Foreground="#FFA5B5D2" FontSize="9" FontWeight="Bold" />
                                    <TextBlock Text="{Binding LastSessionDuration}" Foreground="#FFFFD79C" FontSize="18" FontWeight="SemiBold" Margin="0,2,0,0" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>

                    <local:AdaptiveTwoColumnPanel Margin="0,0,0,20" Breakpoint="1500" Gap="14">
                        <Border x:Name="HeatmapSection" Style="{StaticResource SectionSurface}" Padding="22,20,22,22">
                            <Grid>
                                <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Style="{StaticResource SectionTitle}" Text="Activity over the last 52 weeks" />
                                    <TextBlock Text="Each square represents tracked playtime for one day." Foreground="#FFAAB6CC" FontSize="11" Margin="0,4,0,0" />
                                </StackPanel>
                                <Border Grid.Column="1" Background="#2539C9A6" BorderBrush="#4262D6C6" BorderThickness="1" CornerRadius="10" Padding="10,5" VerticalAlignment="Top">
                                    <TextBlock Text="TRACKED" Foreground="#FFACEDE0" FontSize="10" FontWeight="Bold" />
                                </Border>

                                <ScrollViewer Grid.Row="1" Grid.ColumnSpan="2" Margin="0,18,0,14" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                                    <Grid Width="{Binding ActualWidth, ElementName=HeatmapSection, Converter={StaticResource HeatmapWidthConverter}}" HorizontalAlignment="Center">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="34" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                        <Grid Grid.Column="0">
                                            <Grid.RowDefinitions><RowDefinition Height="*" /><RowDefinition Height="*" /><RowDefinition Height="*" /><RowDefinition Height="*" /><RowDefinition Height="*" /><RowDefinition Height="*" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" Text="MON" Foreground="#758FA0B9" FontSize="9" VerticalAlignment="Center" />
                                            <TextBlock Grid.Row="2" Text="WED" Foreground="#758FA0B9" FontSize="9" VerticalAlignment="Center" />
                                            <TextBlock Grid.Row="4" Text="FRI" Foreground="#758FA0B9" FontSize="9" VerticalAlignment="Center" />
                                        </Grid>
                                        <ItemsControl Grid.Column="1" ItemsSource="{Binding HeatmapCells}" Height="{Binding ActualWidth, RelativeSource={RelativeSource Self}, Converter={StaticResource HeatmapHeightConverter}}">
                                            <ItemsControl.ItemsPanel><ItemsPanelTemplate><UniformGrid Rows="7" Columns="52" /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate><DataTemplate>
                                                <Border Margin="2" Background="{Binding Background}" ToolTip="{Binding Tooltip}" CornerRadius="3" BorderBrush="#1AFFFFFF" BorderThickness="1" />
                                            </DataTemplate></ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Grid>
                                </ScrollViewer>

                                <DockPanel Grid.Row="2" Grid.ColumnSpan="2">
                                    <TextBlock Text="Heatmap starts recording after the extension is installed." Foreground="#809EB1C5" FontSize="10" />
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" DockPanel.Dock="Right">
                                        <TextBlock Text="Less" Foreground="#FFAAB6CC" FontSize="10" VerticalAlignment="Center" Margin="0,0,6,0" />
                                        <Border Width="11" Height="11" Margin="2" CornerRadius="3" Background="#FF363B4A" /><Border Width="11" Height="11" Margin="2" CornerRadius="3" Background="#FF165C44" /><Border Width="11" Height="11" Margin="2" CornerRadius="3" Background="#FF168258" /><Border Width="11" Height="11" Margin="2" CornerRadius="3" Background="#FF23AB6E" /><Border Width="11" Height="11" Margin="2" CornerRadius="3" Background="#FF4BD889" />
                                        <TextBlock Text="More" Foreground="#FFAAB6CC" FontSize="10" VerticalAlignment="Center" Margin="6,0,0,0" />
                                    </StackPanel>
                                </DockPanel>
                            </Grid>
                        </Border>

                        <Border Style="{StaticResource SectionSurface}" Padding="22,20,22,22">
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="0.8*" /><ColumnDefinition Width="1.2*" /></Grid.ColumnDefinitions>
                                <StackPanel VerticalAlignment="Center" Margin="4,4,18,4">
                                    <Border Background="#2B8A66E8" BorderBrush="#5A8E7BFF" BorderThickness="1" CornerRadius="7" Padding="10,5" HorizontalAlignment="Left" Margin="0,0,0,12">
                                        <TextBlock Text="DAILY PATTERN" Foreground="#FFD8E3FF" FontSize="10" FontWeight="Bold" />
                                    </Border>
                                    <TextBlock Text="Rhythm of your day" Foreground="#FFF7FAFF" FontSize="20" FontWeight="SemiBold" TextWrapping="Wrap" />
                                    <TextBlock Text="Which hours do you launch games the most?" Foreground="#FFAFBDD1" FontSize="12" LineHeight="18" TextWrapping="Wrap" Margin="0,8,0,16" />
                                    <Border Background="#4B1E2638" BorderBrush="#325B6D87" BorderThickness="1" CornerRadius="10" Padding="13" Margin="0,0,0,8">
                                        <StackPanel><TextBlock Text="MOST ACTIVE HOUR" Foreground="#FF98A9C2" FontSize="10" FontWeight="Bold" /><TextBlock Text="{Binding PeakHour}" Foreground="#FFE6A7FF" FontSize="17" FontWeight="SemiBold" Margin="0,4,0,0" /></StackPanel>
                                    </Border>
                                    <StackPanel Orientation="Horizontal" Margin="0,16,0,0"><Border Width="9" Height="9" Background="#FF4CBCE8" CornerRadius="5" Margin="0,2,6,0" /><TextBlock Text="Night" Foreground="#FF9EB0C8" FontSize="10" Margin="0,0,12,0" /><Border Width="9" Height="9" Background="#FF9B73DF" CornerRadius="5" Margin="0,2,6,0" /><TextBlock Text="Day" Foreground="#FF9EB0C8" FontSize="10" Margin="0,0,12,0" /><Border Width="9" Height="9" Background="#FFE06BC6" CornerRadius="5" Margin="0,2,6,0" /><TextBlock Text="Evening" Foreground="#FF9EB0C8" FontSize="10" /></StackPanel>
                                </StackPanel>
