                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource MetricCard}" Margin="0">
                            <StackPanel>
                                <TextBlock Text="ACTIVE 30D" Foreground="#FFAAB6CC" FontSize="10" FontWeight="Bold" />
                                <TextBlock Text="{Binding RecentGames}" FontSize="22" FontWeight="SemiBold" Foreground="#FFFFFFFF" Margin="0,6,0,0" />
                                <TextBlock Text="Played in last 30 days" Foreground="#FF8395AE" FontSize="10" Margin="0,6,0,0" />
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <!-- Most played games -->
                    <Border Style="{StaticResource SectionSurface}" Padding="22,20,22,22">
                        <StackPanel>
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <Border Background="#326D83F5" BorderBrush="#507E94F8" BorderThickness="1" CornerRadius="5" Padding="8,3" Margin="0,0,10,0">
                                            <TextBlock Text="TOP 20" Foreground="#FFDDE6FF" FontWeight="Bold" FontSize="10" />
                                        </Border>
                                        <TextBlock Text="LIBRARY RANKING" Foreground="#FF82A9FF" FontWeight="Bold" FontSize="10" VerticalAlignment="Center" />
                                    </StackPanel>
                                    <TextBlock Text="Most played games" Foreground="#FFF7FAFF" FontSize="20" FontWeight="SemiBold" Margin="0,8,0,0" />
                                    <TextBlock Text="Compare all-time favorites with the period you select." Foreground="#FFAAB6CC" FontSize="12" Margin="0,4,0,0" TextWrapping="Wrap" />
                                </StackPanel>
                                <Border Grid.Column="1" Background="#3A1D2639" BorderBrush="#36556A87" BorderThickness="1" CornerRadius="10" Padding="13,9" VerticalAlignment="Bottom" Margin="20,0,0,0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="PERIOD" Foreground="#FF92A5C0" FontSize="10" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,10,0" />
                                        <ComboBox Style="{StaticResource PeriodPicker}" ItemsSource="{Binding PlaytimePeriods}" SelectedItem="{Binding SelectedPlaytimePeriod, Mode=TwoWay}" DisplayMemberPath="Name" />
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <local:AdaptiveTwoColumnPanel Breakpoint="1120" Gap="14">
                                <Border Background="#681B2233" BorderBrush="#3651647F" BorderThickness="1" CornerRadius="12" Padding="14">
                                    <StackPanel>
                                        <DockPanel Margin="2,0,2,12">
                                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center"><Border Width="6" Height="6" CornerRadius="3" Background="#FF7997F8" Margin="0,0,7,0" /><TextBlock Text="ALL-TIME" Foreground="#FF92A5C6" FontWeight="Bold" FontSize="10" VerticalAlignment="Center" /></StackPanel>
                                            <StackPanel><TextBlock Text="Library favorites" Foreground="#FFF5F8FF" FontSize="14" FontWeight="SemiBold" /><TextBlock Text="Total playtime reported by Playnite" Foreground="#FF8FA2BD" FontSize="10" Margin="0,2,0,0" /></StackPanel>
                                        </DockPanel>
                                        <ScrollViewer Height="360" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" PanningMode="VerticalOnly">
                                            <ItemsControl ItemsSource="{Binding TopGames}"><ItemsControl.ItemTemplate><DataTemplate>
                                                <Border Style="{StaticResource RankRow}">
                                                    <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="32" /><ColumnDefinition Width="42" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                                        <Border Width="24" Height="24" CornerRadius="12" Background="#FF29344D" VerticalAlignment="Center"><TextBlock Text="{Binding Rank}" Foreground="#FFB9C7DF" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" /></Border>
                                                        <Border Grid.Column="1" Width="36" Height="44" CornerRadius="6" ClipToBounds="True" Background="#FF252D3F"><Image Source="{Binding CoverPath}" Stretch="UniformToFill" /></Border>
                                                        <Grid Grid.Column="2" Margin="10,2,10,2"><Grid.RowDefinitions><RowDefinition Height="*" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                                                            <TextBlock Text="{Binding Name}" Foreground="#FFF2F5FB" FontWeight="SemiBold" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                                            <ProgressBar Grid.Row="1" Style="{StaticResource RankingProgress}" Value="{Binding RelativePercentage}" Margin="0,5,0,0" />
                                                        </Grid>
                                                        <TextBlock Grid.Column="3" Text="{Binding DurationSeconds, Converter={StaticResource DurationToTextConverter}}" Foreground="#FF9FBBFF" FontWeight="SemiBold" VerticalAlignment="Center" />
                                                    </Grid>
                                                </Border>
                                            </DataTemplate></ItemsControl.ItemTemplate></ItemsControl>
                                        </ScrollViewer>
                                    </StackPanel>
                                </Border>

                                <Border Background="#681B2233" BorderBrush="#3651647F" BorderThickness="1" CornerRadius="12" Padding="14">
                                    <StackPanel>
                                        <DockPanel Margin="2,0,2,12">
                                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center"><Border Width="6" Height="6" CornerRadius="3" Background="#FF49C9AA" Margin="0,0,7,0" /><TextBlock Text="{Binding SelectedPlaytimePeriod.Name}" Foreground="#FF8DCCBE" FontWeight="Bold" FontSize="10" VerticalAlignment="Center" /></StackPanel>
                                            <StackPanel><TextBlock Text="Most played in this period" Foreground="#FFF5F8FF" FontSize="14" FontWeight="SemiBold" /><TextBlock Text="Playtime tracked by Activity Dashboard" Foreground="#FF8FA2BD" FontSize="10" Margin="0,2,0,0" /></StackPanel>
                                        </DockPanel>
                                        <Grid Height="360">
                                            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" PanningMode="VerticalOnly">
                                                <ItemsControl ItemsSource="{Binding FilteredTopGames}"><ItemsControl.ItemTemplate><DataTemplate>
                                                    <Border Style="{StaticResource RankRow}">
                                                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="32" /><ColumnDefinition Width="42" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                                            <Border Width="24" Height="24" CornerRadius="12" Background="#FF243E3D" VerticalAlignment="Center"><TextBlock Text="{Binding Rank}" Foreground="#FFA6EEDC" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" /></Border>
                                                            <Border Grid.Column="1" Width="36" Height="44" CornerRadius="6" ClipToBounds="True" Background="#FF252D3F"><Image Source="{Binding CoverPath}" Stretch="UniformToFill" /></Border>
                                                            <Grid Grid.Column="2" Margin="10,2,10,2"><Grid.RowDefinitions><RowDefinition Height="*" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                                                                <TextBlock Text="{Binding Name}" Foreground="#FFF2F5FB" FontWeight="SemiBold" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                                                <ProgressBar Grid.Row="1" Style="{StaticResource RankingProgress}" Foreground="#FF49C9AA" Value="{Binding RelativePercentage}" Margin="0,5,0,0" />
                                                            </Grid>
                                                            <TextBlock Grid.Column="3" Text="{Binding DurationSeconds, Converter={StaticResource DurationToTextConverter}}" Foreground="#FF85DEC9" FontWeight="SemiBold" VerticalAlignment="Center" />
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate></ItemsControl.ItemTemplate></ItemsControl>
                                            </ScrollViewer>
                                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <StackPanel.Style><Style TargetType="StackPanel"><Setter Property="Visibility" Value="Collapsed" /><Style.Triggers><DataTrigger Binding="{Binding HasFilteredGames}" Value="False"><Setter Property="Visibility" Value="Visible" /></DataTrigger></Style.Triggers></Style></StackPanel.Style>
                                                <Border Width="42" Height="42" Background="#322FC6A4" CornerRadius="21"><TextBlock Text="&#x25F7;" Foreground="#FF83DCC7" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center" /></Border>
                                                <TextBlock Text="No tracked playtime in this period" Foreground="#FFF0F4FA" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,10,0,0" />
                                                <TextBlock Text="Choose a longer period or launch a game." Foreground="#FF91A3BC" FontSize="10" HorizontalAlignment="Center" Margin="0,4,0,0" />
                                            </StackPanel>
                                            <TextBlock Text="Updating ranking..." Foreground="#FF8CE7D2" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,6" Visibility="{Binding IsPeriodLoading, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </local:AdaptiveTwoColumnPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- ====================== ACTIVITY TAB ====================== -->
                <StackPanel Visibility="{Binding IsActivitySelected, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <local:AdaptiveTwoColumnPanel Breakpoint="1200" Gap="14" Margin="0,0,0,14">
                        <Border Style="{StaticResource SectionSurface}">
                            <StackPanel>
                                <DockPanel Margin="0,0,0,12">
                                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center"><Border Width="6" Height="6" CornerRadius="3" Background="#FF6D83F5" Margin="0,0,7,0" /><TextBlock Text="LAST 12 MONTHS" Foreground="#FFA5B5D2" FontWeight="Bold" FontSize="10" VerticalAlignment="Center" /></StackPanel>
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource SectionTitle}" Text="Monthly playtime" />
                                        <TextBlock Text="Hours stacked per month across your tracked history." Foreground="#FFAAB6CC" FontSize="11" Margin="0,3,0,0" />
                                    </StackPanel>
                                </DockPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                    <StackPanel Margin="0,4,0,8">
                                        <TextBlock Text="PEAK MONTH" Foreground="#FFA5B5D2" FontSize="10" FontWeight="Bold" />
                                        <TextBlock Text="{Binding MonthlyPeakLabel}" Foreground="#FFAFBFFF" FontSize="15" FontWeight="SemiBold" Margin="0,3,0,0" />
                                    </StackPanel>
                                    <Border Grid.Column="1" Background="#1A1F2A40" BorderBrush="#30465778" BorderThickness="1" CornerRadius="9" Padding="10,5" VerticalAlignment="Top">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="TOTAL" Foreground="#FFA5B5D2" FontSize="10" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,7,0" />
                                            <TextBlock Text="{Binding MonthlyTotalText}" Foreground="#FFAFBFFF" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Border>
                                </Grid>
                                <local:MonthlyBarsChart Height="200" ItemsSource="{Binding MonthlyBuckets}" HighlightIndex="{Binding MonthlyPeakIndex}" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource SectionSurface}">
                            <StackPanel>
                                <DockPanel Margin="0,0,0,12">
                                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center"><Border Width="6" Height="6" CornerRadius="3" Background="#FF45C9A6" Margin="0,0,7,0" /><TextBlock Text="WEEKLY PATTERN" Foreground="#FFA5B5D2" FontWeight="Bold" FontSize="10" VerticalAlignment="Center" /></StackPanel>
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource SectionTitle}" Text="Weekday distribution" />
                                        <TextBlock Text="Which days of the week do you play the most?" Foreground="#FFAAB6CC" FontSize="11" Margin="0,3,0,0" />
                                    </StackPanel>
                                </DockPanel>
                                <ItemsControl ItemsSource="{Binding WeekdayBreakdown}" Margin="0,4,0,0">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,0,0,8">
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="60" /><ColumnDefinition Width="*" /><ColumnDefinition Width="100" /></Grid.ColumnDefinitions>
                                                <StackPanel VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding ShortLabel}" Foreground="#FFDFE8F8" FontWeight="SemiBold" FontSize="12" />
                                                    <TextBlock Text="{Binding SessionCount, StringFormat={}{0} sessions}" Foreground="#FFA5B5D2" FontSize="10" Margin="0,1,0,0" />
                                                </StackPanel>
                                                <ProgressBar Grid.Column="1" Style="{StaticResource DistributionProgress}" Foreground="{Binding Order, Converter={StaticResource DistributionFillConverter}}" Value="{Binding RelativePercentage}" VerticalAlignment="Center" Margin="8,0" />
                                                <TextBlock Grid.Column="2" Text="{Binding DurationSeconds, Converter={StaticResource DurationToTextConverter}}" Foreground="#FFAFDBC6" FontWeight="SemiBold" FontSize="11" VerticalAlignment="Center" HorizontalAlignment="Right" />
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <TextBlock Text="No tracked sessions yet" Foreground="#FFA5B5D2" FontSize="11" HorizontalAlignment="Center" Margin="0,8,0,0">
                                    <TextBlock.Style><Style TargetType="TextBlock"><Setter Property="Visibility" Value="Collapsed" /><Style.Triggers><DataTrigger Binding="{Binding HasWeekdayData}" Value="False"><Setter Property="Visibility" Value="Visible" /></DataTrigger></Style.Triggers></Style></TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </local:AdaptiveTwoColumnPanel>

                    <local:AdaptiveTwoColumnPanel Breakpoint="1200" Gap="14">
                        <Border Style="{StaticResource SectionSurface}">
                            <StackPanel>
                                <DockPanel Margin="0,0,0,12">
                                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center"><Border Width="6" Height="6" CornerRadius="3" Background="#FFE06BC6" Margin="0,0,7,0" /><TextBlock Text="SESSION LENGTHS" Foreground="#FFA5B5D2" FontWeight="Bold" FontSize="10" VerticalAlignment="Center" /></StackPanel>
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource SectionTitle}" Text="Session length distribution" />
                                        <TextBlock Text="How long your tracked sessions usually last." Foreground="#FFAAB6CC" FontSize="11" Margin="0,3,0,0" />
                                    </StackPanel>
                                </DockPanel>
                                <ItemsControl ItemsSource="{Binding SessionLengthDistribution}" Margin="0,4,0,0">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,0,0,8">
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="100" /><ColumnDefinition Width="*" /><ColumnDefinition Width="80" /></Grid.ColumnDefinitions>
                                                <StackPanel VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Label}" Foreground="#FFDFE8F8" FontWeight="SemiBold" FontSize="12" />
                                                    <TextBlock Text="{Binding Count, StringFormat={}{0} session(s)}" Foreground="#FFA5B5D2" FontSize="10" Margin="0,1,0,0" />
                                                </StackPanel>
                                                <ProgressBar Grid.Column="1" Style="{StaticResource DistributionProgress}" Foreground="{Binding Order, Converter={StaticResource DistributionFillConverter}}" Value="{Binding RelativePercentage}" VerticalAlignment="Center" Margin="8,0" />
                                                <TextBlock Grid.Column="2" Text="{Binding Count, StringFormat={}{0}x}" Foreground="#FFE4B7D4" FontWeight="SemiBold" FontSize="11" VerticalAlignment="Center" HorizontalAlignment="Right" />
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <TextBlock Text="No tracked sessions yet" Foreground="#FFA5B5D2" FontSize="11" HorizontalAlignment="Center" Margin="0,8,0,0">
                                    <TextBlock.Style><Style TargetType="TextBlock"><Setter Property="Visibility" Value="Collapsed" /><Style.Triggers><DataTrigger Binding="{Binding HasSessionLengthData}" Value="False"><Setter Property="Visibility" Value="Visible" /></DataTrigger></Style.Triggers></Style></TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource SectionSurface}">
                            <StackPanel>
                                <DockPanel Margin="0,0,0,12">
                                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center"><Border Width="6" Height="6" CornerRadius="3" Background="#FFE9A34D" Margin="0,0,7,0" /><TextBlock Text="PERSONAL RECORDS" Foreground="#FFA5B5D2" FontWeight="Bold" FontSize="10" VerticalAlignment="Center" /></StackPanel>
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource SectionTitle}" Text="Personal records" />
                                        <TextBlock Text="Longest session, first tracked date and weekend ratio." Foreground="#FFAAB6CC" FontSize="11" Margin="0,3,0,0" />
                                    </StackPanel>
                                </DockPanel>
                                <Grid Margin="0,4,0,0">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                                    <Border Background="#3A1B2236" BorderBrush="#36465778" BorderThickness="1" CornerRadius="10" Padding="14" Margin="0,0,6,8">
                                        <StackPanel>
                                            <TextBlock Text="LONGEST SESSION" Foreground="#FFA5B5D2" FontSize="9" FontWeight="Bold" />
                                            <TextBlock Text="{Binding LongestSessionDuration}" Foreground="#FFFFD79C" FontSize="20" FontWeight="SemiBold" Margin="0,6,0,0" />
                                            <TextBlock Text="{Binding LongestSessionGame}" Foreground="#FFAFC3FF" FontSize="11" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" Margin="0,3,0,0" />
                                            <TextBlock Text="{Binding LongestSessionWhen}" Foreground="#FFA5B5D2" FontSize="10" Margin="0,2,0,0" />
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Column="1" Background="#3A1B2236" BorderBrush="#36465778" BorderThickness="1" CornerRadius="10" Padding="14" Margin="6,0,0,8">
                                        <StackPanel>
                                            <TextBlock Text="LONGEST STREAK" Foreground="#FFA5B5D2" FontSize="9" FontWeight="Bold" />
                                            <TextBlock Text="{Binding LongestStreakText}" Foreground="#FFFFD79C" FontSize="20" FontWeight="SemiBold" Margin="0,6,0,0" />
                                            <TextBlock Text="of consecutive active days" Foreground="#FFA5B5D2" FontSize="10" Margin="0,3,0,0" />
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Row="1" Background="#3A1B2236" BorderBrush="#36465778" BorderThickness="1" CornerRadius="10" Padding="14" Margin="0,0,6,0">
                                        <StackPanel>
                                            <TextBlock Text="WEEKEND RATIO" Foreground="#FFA5B5D2" FontSize="9" FontWeight="Bold" />
                                            <TextBlock Text="{Binding WeekendRatioText}" Foreground="#FFE4B7D4" FontSize="15" FontWeight="SemiBold" Margin="0,6,0,0" TextWrapping="Wrap" />
                                            <TextBlock Text="Sat and Sun share" Foreground="#FFA5B5D2" FontSize="10" Margin="0,3,0,0" />
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Row="1" Grid.Column="1" Background="#3A1B2236" BorderBrush="#36465778" BorderThickness="1" CornerRadius="10" Padding="14" Margin="6,0,0,0">
                                        <StackPanel>
                                            <TextBlock Text="FIRST TRACKED" Foreground="#FFA5B5D2" FontSize="9" FontWeight="Bold" />
                                            <TextBlock Text="{Binding FirstSessionText}" Foreground="#FFAFBFFF" FontSize="15" FontWeight="SemiBold" Margin="0,6,0,0" TextWrapping="Wrap" />
                                            <TextBlock Text="earliest recorded session" Foreground="#FFA5B5D2" FontSize="10" Margin="0,3,0,0" />
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </local:AdaptiveTwoColumnPanel>
                </StackPanel>

                <!-- ====================== LIBRARY TAB ====================== -->
                <StackPanel Visibility="{Binding IsLibrarySelected, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <local:AdaptiveTwoColumnPanel Breakpoint="1200" Gap="14" Margin="0,0,0,14">
                        <Border Style="{StaticResource SectionSurface}">
                            <StackPanel>
                                <DockPanel Margin="0,0,0,12">
                                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center"><Border Width="6" Height="6" CornerRadius="3" Background="#FF45C9A6" Margin="0,0,7,0" /><TextBlock Text="TOP 5" Foreground="#FFA5B5D2" FontWeight="Bold" FontSize="10" VerticalAlignment="Center" /></StackPanel>
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource SectionTitle}" Text="Platforms" />
                                        <TextBlock Text="Playtime by platform from your library." Foreground="#FFAAB6CC" FontSize="11" Margin="0,3,0,0" />
                                    </StackPanel>
                                </DockPanel>
                                <ItemsControl ItemsSource="{Binding Platforms}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,0,0,8">
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="100" /></Grid.ColumnDefinitions>
                                                <StackPanel VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Name}" Foreground="#FFDFE8F8" FontWeight="SemiBold" FontSize="12" TextTrimming="CharacterEllipsis" />
                                                    <ProgressBar Style="{StaticResource DistributionProgress}" Foreground="#FF45C9A6" Value="{Binding RelativePercentage}" Margin="0,4,10,0" />
                                                </StackPanel>
                                                <TextBlock Grid.Column="1" Text="{Binding DurationSeconds, Converter={StaticResource DurationToTextConverter}}" Foreground="#FF8DDFC8" FontWeight="SemiBold" FontSize="11" VerticalAlignment="Center" HorizontalAlignment="Right" />
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <TextBlock Text="No platform data yet" Foreground="#FFA5B5D2" FontSize="11" HorizontalAlignment="Center" Margin="0,6,0,0">
                                    <TextBlock.Style><Style TargetType="TextBlock"><Setter Property="Visibility" Value="Collapsed" /><Style.Triggers><DataTrigger Binding="{Binding HasPlatforms}" Value="False"><Setter Property="Visibility" Value="Visible" /></DataTrigger></Style.Triggers></Style></TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource SectionSurface}">
                            <StackPanel>
                                <DockPanel Margin="0,0,0,12">
                                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center"><Border Width="6" Height="6" CornerRadius="3" Background="#FFE06BC6" Margin="0,0,7,0" /><TextBlock Text="TOP 5" Foreground="#FFA5B5D2" FontWeight="Bold" FontSize="10" VerticalAlignment="Center" /></StackPanel>
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource SectionTitle}" Text="Genres" />
                                        <TextBlock Text="Playtime by genre from your library." Foreground="#FFAAB6CC" FontSize="11" Margin="0,3,0,0" />
                                    </StackPanel>
                                </DockPanel>
                                <ItemsControl ItemsSource="{Binding Genres}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,0,0,8">
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="100" /></Grid.ColumnDefinitions>
                                                <StackPanel VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Name}" Foreground="#FFDFE8F8" FontWeight="SemiBold" FontSize="12" TextTrimming="CharacterEllipsis" />
                                                    <ProgressBar Style="{StaticResource DistributionProgress}" Foreground="#FFE06BC6" Value="{Binding RelativePercentage}" Margin="0,4,10,0" />
                                                </StackPanel>
                                                <TextBlock Grid.Column="1" Text="{Binding DurationSeconds, Converter={StaticResource DurationToTextConverter}}" Foreground="#FFE4B7D4" FontWeight="SemiBold" FontSize="11" VerticalAlignment="Center" HorizontalAlignment="Right" />
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <TextBlock Text="No genre data yet" Foreground="#FFA5B5D2" FontSize="11" HorizontalAlignment="Center" Margin="0,6,0,0">
                                    <TextBlock.Style><Style TargetType="TextBlock"><Setter Property="Visibility" Value="Collapsed" /><Style.Triggers><DataTrigger Binding="{Binding HasGenres}" Value="False"><Setter Property="Visibility" Value="Visible" /></DataTrigger></Style.Triggers></Style></TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </local:AdaptiveTwoColumnPanel>

                    <Border Style="{StaticResource SectionSurface}">
                        <StackPanel>
                            <DockPanel Margin="0,0,0,14">
                                <Border DockPanel.Dock="Right" Background="#32E9A34D" BorderBrush="#55E9A34D" BorderThickness="1" CornerRadius="8" Padding="10,5" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding FavoriteGames.Count, StringFormat={}{0} FAVORITES}" Foreground="#FFFFD79C" FontWeight="Bold" FontSize="10" />
                                </Border>
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#x2605;" Foreground="#FFFFB95E" FontSize="16" Margin="0,-2,8,0" />
                                        <TextBlock Style="{StaticResource SectionTitle}" Text="Favorite games" />
                                    </StackPanel>
                                    <TextBlock Text="Games marked as favorites in your Playnite library." Foreground="#FFAAB6CC" FontSize="11" Margin="0,3,0,0" />
                                </StackPanel>
                            </DockPanel>

                            <Grid MinHeight="120">
                                <ScrollViewer MaxHeight="300" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" PanningMode="VerticalOnly">
                                    <ItemsControl ItemsSource="{Binding FavoriteGames}">
                                        <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel Orientation="Horizontal" /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate><DataTemplate>
                                            <Border Width="260" Height="100" Background="#641E2638" BorderBrush="#34546680" BorderThickness="1" CornerRadius="10" Margin="0,0,10,10" Padding="8" ToolTip="{Binding Name}">
                                                <Grid>
                                                    <Grid.ColumnDefinitions><ColumnDefinition Width="60" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                                    <Border Width="58" Height="84" CornerRadius="7" ClipToBounds="True" Background="#FF252D3F" HorizontalAlignment="Left">
                                                        <Image Source="{Binding CoverPath}" Stretch="UniformToFill" />
                                                    </Border>
                                                    <Grid Grid.Column="1" Margin="10,3,3,3">
                                                        <Grid.RowDefinitions><RowDefinition Height="*" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                                                        <Grid>
                                                            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                                            <TextBlock Text="{Binding Name}" Foreground="#FFF4F7FC" FontWeight="SemiBold" FontSize="12" TextWrapping="Wrap" TextTrimming="CharacterEllipsis" MaxHeight="36" VerticalAlignment="Top" Margin="0,2,6,0" />
                                                            <TextBlock Grid.Column="1" Text="&#x2605;" Foreground="#FFFFB95E" FontSize="13" VerticalAlignment="Top" />
                                                        </Grid>
                                                        <Border Grid.Row="1" Background="#312D3951" CornerRadius="6" Padding="7,4" HorizontalAlignment="Left">
                                                            <StackPanel Orientation="Horizontal"><TextBlock Text="PLAYTIME" Foreground="#FF8395AE" FontSize="9" FontWeight="Bold" Margin="0,0,6,0" VerticalAlignment="Center" /><TextBlock Text="{Binding DurationSeconds, Converter={StaticResource DurationToTextConverter}}" Foreground="#FFC6D4EB" FontSize="10" FontWeight="SemiBold" /></StackPanel>
                                                        </Border>
                                                    </Grid>
                                                </Grid>
                                            </Border>
                                        </DataTemplate></ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>

                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <StackPanel.Style><Style TargetType="StackPanel"><Setter Property="Visibility" Value="Collapsed" /><Style.Triggers><DataTrigger Binding="{Binding HasFavoriteGames}" Value="False"><Setter Property="Visibility" Value="Visible" /></DataTrigger></Style.Triggers></Style></StackPanel.Style>
                                    <Border Width="42" Height="42" Background="#32E9A34D" CornerRadius="21"><TextBlock Text="&#x2606;" Foreground="#FFFFC879" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center" /></Border>
                                    <TextBlock Text="No favorite games yet" Foreground="#FFF2F5FB" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,10,0,0" />
                                    <TextBlock Text="Mark games as favorites in Playnite and refresh." Foreground="#FF91A3BC" FontSize="10" HorizontalAlignment="Center" Margin="0,4,0,0" />
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- ====================== SESSIONS TAB ====================== -->
                <StackPanel Visibility="{Binding IsSessionsSelected, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <local:AdaptiveTwoColumnPanel Breakpoint="900" Gap="14" Margin="0,0,0,14">
                        <Border Style="{StaticResource SectionSurface}">
                            <StackPanel>
                                <DockPanel Margin="0,0,0,10">
                                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center"><Border Width="6" Height="6" CornerRadius="3" Background="#FFE9A34D" Margin="0,0,7,0" /><TextBlock Text="PERSONAL RECORD" Foreground="#FFA5B5D2" FontWeight="Bold" FontSize="10" VerticalAlignment="Center" /></StackPanel>
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource SectionTitle}" Text="Longest session" />
                                        <TextBlock Text="The single longest tracked session." Foreground="#FFAAB6CC" FontSize="11" Margin="0,3,0,0" />
                                    </StackPanel>
                                </DockPanel>
                                <Grid Margin="0,4,0,0">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="{Binding LongestSessionGame}" Foreground="#FFFCF1CF" FontSize="20" FontWeight="SemiBold" TextWrapping="Wrap" />
                                        <TextBlock Text="{Binding LongestSessionWhen}" Foreground="#FFA5B5D2" FontSize="11" Margin="0,5,0,0" />
                                    </StackPanel>
                                    <Border Grid.Column="1" Background="#1A2A344B" BorderBrush="#3FE9A34D" BorderThickness="1" CornerRadius="10" Padding="12,8" VerticalAlignment="Center">
                                        <StackPanel>
                                            <TextBlock Text="DURATION" Foreground="#FFA5B5D2" FontSize="9" FontWeight="Bold" />
                                            <TextBlock Text="{Binding LongestSessionDuration}" Foreground="#FFFFD79C" FontSize="20" FontWeight="SemiBold" Margin="0,3,0,0" />
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource SectionSurface}">
                            <StackPanel>
                                <DockPanel Margin="0,0,0,10">
                                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center"><Border Width="6" Height="6" CornerRadius="3" Background="#FF6D83F5" Margin="0,0,7,0" /><TextBlock Text="MONTHLY SNAPSHOT" Foreground="#FFA5B5D2" FontWeight="Bold" FontSize="10" VerticalAlignment="Center" /></StackPanel>
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource SectionTitle}" Text="Recent monthly peak" />
                                        <TextBlock Text="Your most productive month of the last 12." Foreground="#FFAAB6CC" FontSize="11" Margin="0,3,0,0" />
                                    </StackPanel>
                                </DockPanel>
                                <StackPanel Margin="0,4,0,0">
                                    <TextBlock Text="{Binding MonthlyPeakLabel}" Foreground="#FFAFBFFF" FontSize="20" FontWeight="SemiBold" TextWrapping="Wrap" />
                                    <TextBlock Text="{Binding MonthlyTotalText, StringFormat=Tracked total: {0}}" Foreground="#FFA5B5D2" FontSize="11" Margin="0,5,0,0" />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </local:AdaptiveTwoColumnPanel>

                    <Border Style="{StaticResource SectionSurface}">
                        <StackPanel>
                            <DockPanel Margin="0,0,0,10"><StackPanel><TextBlock Style="{StaticResource SectionTitle}" Text="Recent sessions" /><TextBlock Text="Latest games launched through Playnite" Foreground="#FFAAB6CC" FontSize="11" Margin="0,3,0,0" /></StackPanel><TextBlock DockPanel.Dock="Right" Text="HISTORY" Foreground="#FF82A9FF" FontSize="10" FontWeight="Bold" VerticalAlignment="Center" /></DockPanel>
                            <Border Background="#421E2638" CornerRadius="10" Padding="14" Visibility="Collapsed">
                                <Border.Style><Style TargetType="Border"><Setter Property="Visibility" Value="Collapsed" /><Style.Triggers><DataTrigger Binding="{Binding HasSessions}" Value="False"><Setter Property="Visibility" Value="Visible" /></DataTrigger></Style.Triggers></Style></Border.Style>
                                <StackPanel Orientation="Horizontal"><TextBlock Text="◌" FontSize="24" Foreground="#FF76CDBA" Margin="0,-3,12,0" /><StackPanel><TextBlock Text="Your timeline starts with the next game session" Foreground="#FFF4F7FC" FontWeight="SemiBold" /><TextBlock Text="Launch a game through Playnite to start filling your history." Foreground="#FFAAB6CC" FontSize="11" Margin="0,3,0,0" /></StackPanel></StackPanel>
                            </Border>
                            <ItemsControl ItemsSource="{Binding RecentSessions}"><ItemsControl.ItemTemplate><DataTemplate>
                                <Border Style="{StaticResource RankRow}"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="130" /><ColumnDefinition Width="90" /></Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding GameName}" Foreground="#FFF3F6FC" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="1" Text="{Binding EndedAtLocal, StringFormat={}{0:ddd, dd MMM · HH:mm}}" Foreground="#FF9FB0C8" VerticalAlignment="Center" FontSize="11" />
                                    <TextBlock Grid.Column="2" Text="{Binding DurationSeconds, Converter={StaticResource DurationToTextConverter}}" Foreground="#FF82DCC4" FontWeight="SemiBold" HorizontalAlignment="Right" VerticalAlignment="Center" />
                                </Grid></Border>
                            </DataTemplate></ItemsControl.ItemTemplate></ItemsControl>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
