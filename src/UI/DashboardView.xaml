                                </Grid>
                            </Grid>
                        </Border>
                    </local:AdaptiveTwoColumnPanel>

                    <UniformGrid Columns="4" Rows="1" Margin="0,0,0,20">
                        <Border Style="{StaticResource MetricCard}" Margin="0,0,14,0">
                            <StackPanel>
                                <TextBlock Text="TOTAL PLAYTIME" Foreground="#FFAAB6CC" FontSize="10" FontWeight="Bold" />
                                <TextBlock Text="{Binding TotalPlaytime}" FontSize="22" FontWeight="SemiBold" Foreground="#FFFFFFFF" Margin="0,6,0,0" />
                                <TextBlock Text="All-time from Playnite" Foreground="#FF8395AE" FontSize="10" Margin="0,6,0,0" />
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource MetricCard}" Margin="0,0,14,0">
                            <StackPanel>
                                <TextBlock Text="GAMES PLAYED" Foreground="#FFAAB6CC" FontSize="10" FontWeight="Bold" />
                                <TextBlock Text="{Binding GamesPlayed}" FontSize="22" FontWeight="SemiBold" Foreground="#FFFFFFFF" Margin="0,6,0,0" />
                                <TextBlock Text="Tracked or launched" Foreground="#FF8395AE" FontSize="10" Margin="0,6,0,0" />
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource MetricCard}" Margin="0,0,14,0">
                            <StackPanel>
                                <TextBlock Text="LAUNCHES" Foreground="#FFAAB6CC" FontSize="10" FontWeight="Bold" />
