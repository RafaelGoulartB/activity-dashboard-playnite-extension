<UserControl x:Class="ActivityDashboard.UI.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:ActivityDashboard.UI"
             Background="Transparent"
             TextOptions.TextFormattingMode="Display">
    <UserControl.Resources>
        <local:DurationToTextConverter x:Key="DurationToTextConverter" />
        <local:HeatmapHeightConverter x:Key="HeatmapHeightConverter" />
        <local:HeatmapWidthConverter x:Key="HeatmapWidthConverter" />
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <DropShadowEffect x:Key="PanelShadow" BlurRadius="18" ShadowDepth="5" Opacity="0.32" Color="#000000" />

        <Style x:Key="SectionSurface" TargetType="Border">
            <Setter Property="Background" Value="#E9161B2A" />
            <Setter Property="BorderBrush" Value="#2742506B" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Padding" Value="22" />
            <Setter Property="Effect" Value="{StaticResource PanelShadow}" />
        </Style>

        <Style x:Key="MetricCard" TargetType="Border">
            <Setter Property="Background" Value="#E91B2132" />
            <Setter Property="BorderBrush" Value="#36505C75" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="MinWidth" Value="190" />
            <Setter Property="Margin" Value="0,0,14,14" />
            <Setter Property="Effect" Value="{StaticResource PanelShadow}" />
        </Style>

        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FFF7FAFF" />
            <Setter Property="FontSize" Value="17" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="RefreshButton" TargetType="Button">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="#3B68E6C6" />
            <Setter Property="BorderBrush" Value="#856EE7D2" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="18,10" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Surface" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="9">
                            <ContentPresenter Margin="{TemplateBinding Padding}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Surface" Property="Background" Value="#5A75F2D9" /></Trigger>
                            <Trigger Property="IsPressed" Value="True"><Setter TargetName="Surface" Property="Background" Value="#2F4FC1A7" /></Trigger>
                            <Trigger Property="IsEnabled" Value="False"><Setter TargetName="Surface" Property="Opacity" Value="0.45" /></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RankRow" TargetType="Border">
            <Setter Property="Background" Value="#521E2638" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="9,8" />
            <Setter Property="Margin" Value="0,0,0,7" />
        </Style>

        <Style x:Key="RankingProgress" TargetType="ProgressBar">
            <Setter Property="Height" Value="4" />
            <Setter Property="Maximum" Value="100" />
            <Setter Property="Background" Value="#FF293248" />
            <Setter Property="Foreground" Value="#FF7697F7" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Grid ClipToBounds="True">
                            <Border Background="{TemplateBinding Background}" CornerRadius="2" />
                            <Border x:Name="PART_Indicator" Background="{TemplateBinding Foreground}" CornerRadius="2" HorizontalAlignment="Left" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PeriodPickerItem" TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="#FFDCE5F5" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="12,9" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemSurface" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}" Margin="3,2">
                            <ContentPresenter VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True"><Setter TargetName="ItemSurface" Property="Background" Value="#FF303D59" /><Setter Property="Foreground" Value="#FFFFFFFF" /></Trigger>
                            <Trigger Property="IsSelected" Value="True"><Setter TargetName="ItemSurface" Property="Background" Value="#FF34476D" /><Setter Property="Foreground" Value="#FFC9D7FF" /></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PeriodPicker" TargetType="ComboBox">
            <Setter Property="Foreground" Value="#FFF2F6FF" />
            <Setter Property="Background" Value="#FF20283A" />
            <Setter Property="BorderBrush" Value="#FF465875" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="MinWidth" Value="176" />
            <Setter Property="Height" Value="36" />
            <Setter Property="ItemContainerStyle" Value="{StaticResource PeriodPickerItem}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="PickerButton" Focusable="False" ClickMode="Press" Foreground="#FFF2F6FF" IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="PickerSurface" Background="#FF20283A" BorderBrush="#FF465875" BorderThickness="1" CornerRadius="8">
                                            <Grid Margin="12,0,10,0">
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="22" /></Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding SelectedPlaytimePeriod.Name}" Foreground="#FFF2F6FF" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                                <TextBlock Grid.Column="1" Text="&#x2304;" Foreground="#FF91A4C2" FontSize="15" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,-3,0,0" />
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="PickerSurface" Property="Background" Value="#FF29344B" /><Setter TargetName="PickerSurface" Property="BorderBrush" Value="#FF647A9F" /></Trigger>
                                            <Trigger Property="IsChecked" Value="True"><Setter TargetName="PickerSurface" Property="Background" Value="#FF29344B" /><Setter TargetName="PickerSurface" Property="BorderBrush" Value="#FF7895C8" /></Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <Popup x:Name="PART_Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}" AllowsTransparency="True" Focusable="False" PopupAnimation="Fade">
                                <Grid MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}" Margin="0,5,0,0">
                                    <Border Background="#FF171E2D" BorderBrush="#FF465875" BorderThickness="1" CornerRadius="9" Padding="3" Effect="{StaticResource PanelShadow}">
                                        <ScrollViewer MaxHeight="260" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                            <ItemsPresenter />
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="HasItems" Value="False"><Setter TargetName="PART_Popup" Property="MinHeight" Value="36" /></Trigger>
                            <Trigger Property="IsEnabled" Value="False"><Setter TargetName="PickerButton" Property="Opacity" Value="0.45" /></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#FF080C1B" Offset="0" />
                <GradientStop Color="#FF11142A" Offset="0.48" />
                <GradientStop Color="#FF090D1D" Offset="1" />
            </LinearGradientBrush>
        </Grid.Background>
        <Ellipse Width="680" Height="520" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="-210,-270,0,0" IsHitTestVisible="False" Opacity="0.24">
            <Ellipse.Fill><RadialGradientBrush><GradientStop Color="#FF6657E8" Offset="0" /><GradientStop Color="#006657E8" Offset="1" /></RadialGradientBrush></Ellipse.Fill>
        </Ellipse>
        <Ellipse Width="620" Height="400" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-220,-160,0" IsHitTestVisible="False" Opacity="0.16">
            <Ellipse.Fill><RadialGradientBrush><GradientStop Color="#FF2BC5A3" Offset="0" /><GradientStop Color="#002BC5A3" Offset="1" /></RadialGradientBrush></Ellipse.Fill>
        </Ellipse>

        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" PanningMode="VerticalOnly">
            <StackPanel Margin="46,34,46,46">
                <!-- Hero -->
                <Border CornerRadius="18" BorderBrush="#386D75A5" BorderThickness="1" Margin="0,0,0,22" Padding="28,24" Effect="{StaticResource PanelShadow}">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#ED202743" Offset="0" />
                            <GradientStop Color="#E9192238" Offset="0.55" />
                            <GradientStop Color="#E919313D" Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <Border Background="#2F77E9D4" CornerRadius="4" Padding="8,3" Margin="0,0,10,0"><TextBlock Text="LIBRARY" FontWeight="Bold" FontSize="10" Foreground="#FFE2FFFA" /></Border>
                                <TextBlock Text="ACTIVITY OVERVIEW" Foreground="#AFC5CBDC" FontWeight="SemiBold" FontSize="10" VerticalAlignment="Center" />
                            </StackPanel>
                            <TextBlock Text="Activity Dashboard" FontSize="31" FontWeight="SemiBold" Foreground="#FFF9FBFF" />
                            <TextBlock Text="Track your gaming habits, playtime and progress throughout the year." Foreground="#C9D7DDEC" FontSize="14" Margin="0,6,0,0" />
                        </StackPanel>
                        <Button Grid.Column="1" Style="{StaticResource RefreshButton}" Click="Refresh_Click" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal"><TextBlock Text="↻" FontSize="18" Margin="0,-2,7,0" /><TextBlock Text="Refresh data" FontWeight="SemiBold" /></StackPanel>
                        </Button>
                    </Grid>
                </Border>

                <TextBlock Text="Loading Playnite data..." Foreground="#FF9DF1D5" Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}" Margin="4,0,0,12" />
                <TextBlock Text="{Binding ErrorMessage}" Foreground="#FFFF9C9C" TextWrapping="Wrap" Margin="4,0,0,12" />

                <!-- Adaptive activity visualizations -->
                <local:AdaptiveTwoColumnPanel Margin="0,0,0,18" Breakpoint="1500" Gap="18">
                <!-- Heatmap and metrics -->
                <StackPanel>
                <Border x:Name="HeatmapSection" Style="{StaticResource SectionSurface}">
                    <Grid>
                        <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionTitle}" Text="Activity over the last 52 weeks" />
                            <TextBlock Text="Each square represents tracked playtime for one day." Foreground="#FFAAB6CC" FontSize="12" Margin="0,5,0,0" />
                        </StackPanel>
                        <Border Grid.Column="1" Background="#2539C9A6" BorderBrush="#4262D6C6" BorderThickness="1" CornerRadius="10" Padding="10,5" VerticalAlignment="Top">
                            <TextBlock Text="TRACKED SESSIONS" Foreground="#FFACEDE0" FontSize="10" FontWeight="Bold" />
                        </Border>

                        <ScrollViewer Grid.Row="1" Grid.ColumnSpan="2" Margin="0,22,0,16" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                            <Grid Width="{Binding ActualWidth, ElementName=HeatmapSection, Converter={StaticResource HeatmapWidthConverter}}" HorizontalAlignment="Center">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="34" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                <Grid Grid.Column="0">
                                    <Grid.RowDefinitions><RowDefinition Height="*" /><RowDefinition Height="*" /><RowDefinition Height="*" /><RowDefinition Height="*" /><RowDefinition Height="*" /><RowDefinition Height="*" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Text="MON" Foreground="#758FA0B9" FontSize="9" VerticalAlignment="Center" />
                                    <TextBlock Grid.Row="2" Text="WED" Foreground="#758FA0B9" FontSize="9" VerticalAlignment="Center" />
                                    <TextBlock Grid.Row="4" Text="FRI" Foreground="#758FA0B9" FontSize="9" VerticalAlignment="Center" />
                                </Grid>
                                <ItemsControl Grid.Column="1" ItemsSource="{Binding HeatmapCells}" Height="{Binding ActualWidth, RelativeSource={RelativeSource Self}, Converter={StaticResource HeatmapHeightConverter}}">
                                    <ItemsControl.ItemsPanel><ItemsPanelTemplate><UniformGrid Rows="7" Columns="52" /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate><DataTemplate>
                                        <Border Margin="2" Background="{Binding Background}" ToolTip="{Binding Tooltip}" CornerRadius="3" BorderBrush="#1AFFFFFF" BorderThickness="1" />
                                    </DataTemplate></ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>
                        </ScrollViewer>

                        <DockPanel Grid.Row="2" Grid.ColumnSpan="2">
                            <TextBlock Text="The heatmap starts recording after the extension is installed." Foreground="#809EB1C5" FontSize="11" />
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" DockPanel.Dock="Right">
                                <TextBlock Text="Less" Foreground="#FFAAB6CC" FontSize="11" VerticalAlignment="Center" Margin="0,0,7,0" />
                                <Border Width="13" Height="13" Margin="2" CornerRadius="3" Background="#FF363B4A" /><Border Width="13" Height="13" Margin="2" CornerRadius="3" Background="#FF165C44" /><Border Width="13" Height="13" Margin="2" CornerRadius="3" Background="#FF168258" /><Border Width="13" Height="13" Margin="2" CornerRadius="3" Background="#FF23AB6E" /><Border Width="13" Height="13" Margin="2" CornerRadius="3" Background="#FF4BD889" />
                                <TextBlock Text="More" Foreground="#FFAAB6CC" FontSize="11" VerticalAlignment="Center" Margin="7,0,0,0" />
                            </StackPanel>
                        </DockPanel>
                    </Grid>
                </Border>

                <Grid Margin="0,18,0,0">
                    <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                    <Border Style="{StaticResource MetricCard}" Margin="0,0,14,14">
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                            <StackPanel><TextBlock Text="TOTAL PLAYTIME" Foreground="#FFAAB6CC" FontSize="10" FontWeight="Bold" /><TextBlock Text="{Binding TotalPlaytime}" FontSize="25" FontWeight="SemiBold" Foreground="#FFFFFFFF" Margin="0,7,0,0" /></StackPanel>
                            <Border Grid.Column="1" Width="38" Height="38" Background="#355E79F5" CornerRadius="10"><TextBlock Text="&#x25F7;" FontSize="21" Foreground="#FFD9E3FF" HorizontalAlignment="Center" VerticalAlignment="Center" /></Border>
                        </Grid>
                    </Border>
                    <Border Grid.Column="1" Style="{StaticResource MetricCard}" Margin="0,0,0,14">
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                            <StackPanel><TextBlock Text="GAMES PLAYED" Foreground="#FFAAB6CC" FontSize="10" FontWeight="Bold" /><TextBlock Text="{Binding GamesPlayed}" FontSize="25" FontWeight="SemiBold" Foreground="#FFFFFFFF" Margin="0,7,0,0" /></StackPanel>
                            <Border Grid.Column="1" Width="38" Height="38" Background="#3545C9A6" CornerRadius="10"><TextBlock Text="&#x25C6;" FontSize="17" Foreground="#FFD6FFF4" HorizontalAlignment="Center" VerticalAlignment="Center" /></Border>
                        </Grid>
                    </Border>
                    <Border Grid.Row="1" Style="{StaticResource MetricCard}" Margin="0,0,14,0">
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                            <StackPanel><TextBlock Text="GAME LAUNCHES" Foreground="#FFAAB6CC" FontSize="10" FontWeight="Bold" /><TextBlock Text="{Binding TotalLaunches}" FontSize="25" FontWeight="SemiBold" Foreground="#FFFFFFFF" Margin="0,7,0,0" /></StackPanel>
                            <Border Grid.Column="1" Width="38" Height="38" Background="#35E9A34D" CornerRadius="10"><TextBlock Text="&#x25B6;" FontSize="16" Foreground="#FFFFEDCF" HorizontalAlignment="Center" VerticalAlignment="Center" /></Border>
                        </Grid>
                    </Border>
                    <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource MetricCard}" Margin="0">
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                            <StackPanel><TextBlock Text="ACTIVE IN 30 DAYS" Foreground="#FFAAB6CC" FontSize="10" FontWeight="Bold" /><TextBlock Text="{Binding RecentGames}" FontSize="25" FontWeight="SemiBold" Foreground="#FFFFFFFF" Margin="0,7,0,0" /></StackPanel>
                            <Border Grid.Column="1" Width="38" Height="38" Background="#35CC60B5" CornerRadius="10"><TextBlock Text="&#x2726;" FontSize="19" Foreground="#FFFFD9F5" HorizontalAlignment="Center" VerticalAlignment="Center" /></Border>
                        </Grid>
                    </Border>
                </Grid>
                </StackPanel>

                <!-- Hourly radial activity chart -->
                <Border Style="{StaticResource SectionSurface}">
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="0.8*" /><ColumnDefinition Width="1.2*" /></Grid.ColumnDefinitions>
                        <StackPanel VerticalAlignment="Center" Margin="8,8,26,8">
                            <Border Background="#2B8A66E8" BorderBrush="#5A8E7BFF" BorderThickness="1" CornerRadius="7" Padding="10,5" HorizontalAlignment="Left" Margin="0,0,0,16">
                                <TextBlock Text="DAILY PATTERN" Foreground="#FFD8E3FF" FontSize="10" FontWeight="Bold" />
                            </Border>
                            <TextBlock Text="Your rhythm throughout the day" Foreground="#FFF7FAFF" FontSize="25" FontWeight="SemiBold" TextWrapping="Wrap" />
                            <TextBlock Text="Discover which hours you most often launch games from Playnite." Foreground="#FFAFBDD1" FontSize="14" LineHeight="21" TextWrapping="Wrap" Margin="0,10,0,24" />
                            <Border Background="#4B1E2638" BorderBrush="#325B6D87" BorderThickness="1" CornerRadius="10" Padding="15" Margin="0,0,0,10">
                                <StackPanel><TextBlock Text="MOST ACTIVE HOUR" Foreground="#FF98A9C2" FontSize="10" FontWeight="Bold" /><TextBlock Text="{Binding PeakHour}" Foreground="#FFE6A7FF" FontSize="20" FontWeight="SemiBold" Margin="0,5,0,0" /></StackPanel>
                            </Border>
                            <Border Background="#4B1E2638" BorderBrush="#325B6D87" BorderThickness="1" CornerRadius="10" Padding="15">
                                <StackPanel><TextBlock Text="TRACKED PLAYTIME" Foreground="#FF98A9C2" FontSize="10" FontWeight="Bold" /><TextBlock Text="{Binding TrackedPlaytime}" Foreground="#FF8CE7D2" FontSize="20" FontWeight="SemiBold" Margin="0,5,0,0" /></StackPanel>
                            </Border>
                            <StackPanel Orientation="Horizontal" Margin="0,22,0,0"><Border Width="10" Height="10" Background="#FF4CBCE8" CornerRadius="5" Margin="0,2,7,0" /><TextBlock Text="Late night" Foreground="#FF9EB0C8" FontSize="11" Margin="0,0,14,0" /><Border Width="10" Height="10" Background="#FF9B73DF" CornerRadius="5" Margin="0,2,7,0" /><TextBlock Text="Daytime" Foreground="#FF9EB0C8" FontSize="11" Margin="0,0,14,0" /><Border Width="10" Height="10" Background="#FFE06BC6" CornerRadius="5" Margin="0,2,7,0" /><TextBlock Text="Evening" Foreground="#FF9EB0C8" FontSize="11" /></StackPanel>
                        </StackPanel>
                        <Grid Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Border Width="496" Height="496" Background="#2810172A" BorderBrush="#274B5E7A" BorderThickness="1" CornerRadius="248" />
                            <local:HourlyActivityChart Width="496" Height="496" ItemsSource="{Binding HourlyActivity}" />
                        </Grid>
                    </Grid>
                </Border>
                </local:AdaptiveTwoColumnPanel>

                <!-- Most played games -->
                <Border Style="{StaticResource SectionSurface}" Margin="0,0,0,18">
                    <StackPanel>
                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <Border Background="#326D83F5" BorderBrush="#507E94F8" BorderThickness="1" CornerRadius="5" Padding="8,3" Margin="0,0,10,0">
                                        <TextBlock Text="LIBRARY RANKING" Foreground="#FFDDE6FF" FontWeight="Bold" FontSize="10" />
                                    </Border>
                                    <TextBlock Text="TOP 20" Foreground="#FF82A9FF" FontWeight="Bold" FontSize="10" VerticalAlignment="Center" />
                                </StackPanel>
                                <TextBlock Text="Most played games" Foreground="#FFF7FAFF" FontSize="25" FontWeight="SemiBold" Margin="0,9,0,0" />
                                <TextBlock Text="Compare your all-time favorites with the games you have played most in a specific period." Foreground="#FFAAB6CC" FontSize="13" Margin="0,6,0,0" TextWrapping="Wrap" />
                            </StackPanel>
                            <Border Grid.Column="1" Background="#3A1D2639" BorderBrush="#36556A87" BorderThickness="1" CornerRadius="10" Padding="13,9" VerticalAlignment="Bottom" Margin="24,0,0,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="PERIOD" Foreground="#FF92A5C0" FontSize="10" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,10,0" />
                                    <ComboBox Style="{StaticResource PeriodPicker}" ItemsSource="{Binding PlaytimePeriods}" SelectedItem="{Binding SelectedPlaytimePeriod, Mode=TwoWay}" DisplayMemberPath="Name" />
                                </StackPanel>
                            </Border>
                        </Grid>

                        <local:AdaptiveTwoColumnPanel Breakpoint="1120" Gap="16">
                            <Border Background="#681B2233" BorderBrush="#3651647F" BorderThickness="1" CornerRadius="12" Padding="16">
                                <StackPanel>
                                    <DockPanel Margin="2,0,2,14">
                                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center"><Border Width="6" Height="6" CornerRadius="3" Background="#FF7997F8" Margin="0,0,7,0" /><TextBlock Text="ALL-TIME DATA" Foreground="#FF92A5C6" FontWeight="Bold" FontSize="10" VerticalAlignment="Center" /></StackPanel>
                                        <StackPanel><TextBlock Text="Library favorites" Foreground="#FFF5F8FF" FontSize="16" FontWeight="SemiBold" /><TextBlock Text="Total playtime reported by Playnite" Foreground="#FF8FA2BD" FontSize="11" Margin="0,3,0,0" /></StackPanel>
                                    </DockPanel>
                                    <ScrollViewer Height="390" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" PanningMode="VerticalOnly">
                                        <ItemsControl ItemsSource="{Binding TopGames}"><ItemsControl.ItemTemplate><DataTemplate>
                                            <Border Style="{StaticResource RankRow}">
                                                <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="32" /><ColumnDefinition Width="44" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                                    <Border Width="25" Height="25" CornerRadius="13" Background="#FF29344D" VerticalAlignment="Center"><TextBlock Text="{Binding Rank}" Foreground="#FFB9C7DF" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" /></Border>
                                                    <Border Grid.Column="1" Width="38" Height="48" CornerRadius="7" ClipToBounds="True" Background="#FF252D3F"><Image Source="{Binding CoverPath}" Stretch="UniformToFill" /></Border>
                                                    <Grid Grid.Column="2" Margin="10,2,12,2"><Grid.RowDefinitions><RowDefinition Height="*" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                                                        <TextBlock Text="{Binding Name}" Foreground="#FFF2F5FB" FontWeight="SemiBold" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                                        <ProgressBar Grid.Row="1" Style="{StaticResource RankingProgress}" Value="{Binding RelativePercentage}" Margin="0,7,0,0" />
                                                    </Grid>
                                                    <TextBlock Grid.Column="3" Text="{Binding DurationSeconds, Converter={StaticResource DurationToTextConverter}}" Foreground="#FF9FBBFF" FontWeight="SemiBold" VerticalAlignment="Center" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate></ItemsControl.ItemTemplate></ItemsControl>
                                    </ScrollViewer>
                                </StackPanel>
                            </Border>

                            <Border Background="#681B2233" BorderBrush="#3651647F" BorderThickness="1" CornerRadius="12" Padding="16">
                                <StackPanel>
                                    <DockPanel Margin="2,0,2,14">
                                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center"><Border Width="6" Height="6" CornerRadius="3" Background="#FF49C9AA" Margin="0,0,7,0" /><TextBlock Text="{Binding SelectedPlaytimePeriod.Name}" Foreground="#FF8DCCBE" FontWeight="Bold" FontSize="10" VerticalAlignment="Center" /></StackPanel>
                                        <StackPanel><TextBlock Text="Most played in this period" Foreground="#FFF5F8FF" FontSize="16" FontWeight="SemiBold" /><TextBlock Text="Playtime tracked by Activity Dashboard" Foreground="#FF8FA2BD" FontSize="11" Margin="0,3,0,0" /></StackPanel>
                                    </DockPanel>
                                    <Grid Height="390">
                                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" PanningMode="VerticalOnly">
                                            <ItemsControl ItemsSource="{Binding FilteredTopGames}"><ItemsControl.ItemTemplate><DataTemplate>
                                                <Border Style="{StaticResource RankRow}">
                                                    <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="32" /><ColumnDefinition Width="44" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                                        <Border Width="25" Height="25" CornerRadius="13" Background="#FF243E3D" VerticalAlignment="Center"><TextBlock Text="{Binding Rank}" Foreground="#FFA6EEDC" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" /></Border>
                                                        <Border Grid.Column="1" Width="38" Height="48" CornerRadius="7" ClipToBounds="True" Background="#FF252D3F"><Image Source="{Binding CoverPath}" Stretch="UniformToFill" /></Border>
                                                        <Grid Grid.Column="2" Margin="10,2,12,2"><Grid.RowDefinitions><RowDefinition Height="*" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                                                            <TextBlock Text="{Binding Name}" Foreground="#FFF2F5FB" FontWeight="SemiBold" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                                            <ProgressBar Grid.Row="1" Style="{StaticResource RankingProgress}" Foreground="#FF49C9AA" Value="{Binding RelativePercentage}" Margin="0,7,0,0" />
                                                        </Grid>
                                                        <TextBlock Grid.Column="3" Text="{Binding DurationSeconds, Converter={StaticResource DurationToTextConverter}}" Foreground="#FF85DEC9" FontWeight="SemiBold" VerticalAlignment="Center" />
                                                    </Grid>
                                                </Border>
                                            </DataTemplate></ItemsControl.ItemTemplate></ItemsControl>
                                        </ScrollViewer>
                                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <StackPanel.Style><Style TargetType="StackPanel"><Setter Property="Visibility" Value="Collapsed" /><Style.Triggers><DataTrigger Binding="{Binding HasFilteredGames}" Value="False"><Setter Property="Visibility" Value="Visible" /></DataTrigger></Style.Triggers></Style></StackPanel.Style>
                                            <Border Width="46" Height="46" Background="#322FC6A4" CornerRadius="23"><TextBlock Text="&#x25F7;" Foreground="#FF83DCC7" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center" /></Border>
                                            <TextBlock Text="No tracked playtime in this period" Foreground="#FFF0F4FA" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,12,0,0" />
                                            <TextBlock Text="Choose a longer period or launch a game through Playnite." Foreground="#FF91A3BC" FontSize="11" HorizontalAlignment="Center" Margin="0,5,0,0" />
                                        </StackPanel>
                                        <TextBlock Text="Updating ranking..." Foreground="#FF8CE7D2" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,8" Visibility="{Binding IsPeriodLoading, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </local:AdaptiveTwoColumnPanel>
                    </StackPanel>
                </Border>

                <!-- Playnite favorites -->
                <Border Style="{StaticResource SectionSurface}" Margin="0,0,0,18">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,18">
                            <Border DockPanel.Dock="Right" Background="#32E9A34D" BorderBrush="#55E9A34D" BorderThickness="1" CornerRadius="8" Padding="10,5" VerticalAlignment="Center">
                                <TextBlock Text="{Binding FavoriteGames.Count, StringFormat={}{0} FAVORITES}" Foreground="#FFFFD79C" FontWeight="Bold" FontSize="10" />
                            </Border>
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#x2605;" Foreground="#FFFFB95E" FontSize="18" Margin="0,-2,8,0" />
                                    <TextBlock Style="{StaticResource SectionTitle}" Text="Favorite games" />
                                </StackPanel>
                                <TextBlock Text="Games marked as favorites in your Playnite library." Foreground="#FFAAB6CC" FontSize="12" Margin="0,5,0,0" />
                            </StackPanel>
                        </DockPanel>

                        <Grid MinHeight="132">
                            <ScrollViewer MaxHeight="365" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" PanningMode="VerticalOnly">
                                <ItemsControl ItemsSource="{Binding FavoriteGames}">
                                    <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel Orientation="Horizontal" /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate><DataTemplate>
                                        <Border Width="275" Height="112" Background="#641E2638" BorderBrush="#34546680" BorderThickness="1" CornerRadius="11" Margin="0,0,11,11" Padding="9" ToolTip="{Binding Name}">
                                            <Grid>
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="68" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                                <Border Width="62" Height="92" CornerRadius="8" ClipToBounds="True" Background="#FF252D3F" HorizontalAlignment="Left">
                                                    <Image Source="{Binding CoverPath}" Stretch="UniformToFill" />
                                                </Border>
                                                <Grid Grid.Column="1" Margin="11,3,3,3">
                                                    <Grid.RowDefinitions><RowDefinition Height="*" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                                        <TextBlock Text="{Binding Name}" Foreground="#FFF4F7FC" FontWeight="SemiBold" FontSize="13" TextWrapping="Wrap" TextTrimming="CharacterEllipsis" MaxHeight="40" VerticalAlignment="Top" Margin="0,2,8,0" />
                                                        <TextBlock Grid.Column="1" Text="&#x2605;" Foreground="#FFFFB95E" FontSize="14" VerticalAlignment="Top" />
                                                    </Grid>
                                                    <Border Grid.Row="1" Background="#312D3951" CornerRadius="6" Padding="8,5" HorizontalAlignment="Left">
                                                        <StackPanel Orientation="Horizontal"><TextBlock Text="PLAYTIME" Foreground="#FF8395AE" FontSize="9" FontWeight="Bold" Margin="0,0,7,0" VerticalAlignment="Center" /><TextBlock Text="{Binding DurationSeconds, Converter={StaticResource DurationToTextConverter}}" Foreground="#FFC6D4EB" FontSize="11" FontWeight="SemiBold" /></StackPanel>
                                                    </Border>
                                                </Grid>
                                            </Grid>
                                        </Border>
                                    </DataTemplate></ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>

                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <StackPanel.Style><Style TargetType="StackPanel"><Setter Property="Visibility" Value="Collapsed" /><Style.Triggers><DataTrigger Binding="{Binding HasFavoriteGames}" Value="False"><Setter Property="Visibility" Value="Visible" /></DataTrigger></Style.Triggers></Style></StackPanel.Style>
                                <Border Width="48" Height="48" Background="#32E9A34D" CornerRadius="24"><TextBlock Text="&#x2606;" Foreground="#FFFFC879" FontSize="27" HorizontalAlignment="Center" VerticalAlignment="Center" /></Border>
                                <TextBlock Text="No favorite games yet" Foreground="#FFF2F5FB" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,12,0,0" />
                                <TextBlock Text="Mark games as favorites in Playnite and refresh the dashboard." Foreground="#FF91A3BC" FontSize="11" HorizontalAlignment="Center" Margin="0,5,0,0" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Recent activity -->
                <Border Style="{StaticResource SectionSurface}" Margin="0,0,0,12">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,13"><StackPanel><TextBlock Style="{StaticResource SectionTitle}" Text="Recent sessions" /><TextBlock Text="Latest games launched through Playnite" Foreground="#FFAAB6CC" FontSize="12" Margin="0,4,0,0" /></StackPanel><TextBlock DockPanel.Dock="Right" Text="HISTORY" Foreground="#FF82A9FF" FontSize="10" FontWeight="Bold" VerticalAlignment="Center" /></DockPanel>
                        <Border Background="#421E2638" CornerRadius="10" Padding="16" Visibility="Collapsed">
                            <Border.Style><Style TargetType="Border"><Setter Property="Visibility" Value="Collapsed" /><Style.Triggers><DataTrigger Binding="{Binding HasSessions}" Value="False"><Setter Property="Visibility" Value="Visible" /></DataTrigger></Style.Triggers></Style></Border.Style>
                            <StackPanel Orientation="Horizontal"><TextBlock Text="◌" FontSize="28" Foreground="#FF76CDBA" Margin="0,-3,12,0" /><StackPanel><TextBlock Text="Your timeline starts with the next game session" Foreground="#FFF4F7FC" FontWeight="SemiBold" /><TextBlock Text="Launch a game through Playnite to start filling your heatmap." Foreground="#FFAAB6CC" FontSize="12" Margin="0,4,0,0" /></StackPanel></StackPanel>
                        </Border>
                        <ItemsControl ItemsSource="{Binding RecentSessions}"><ItemsControl.ItemTemplate><DataTemplate>
                            <Border Style="{StaticResource RankRow}"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="150" /><ColumnDefinition Width="100" /></Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding GameName}" Foreground="#FFF3F6FC" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="1" Text="{Binding EndedAtLocal, StringFormat={}{0:ddd, dd MMM · HH:mm}}" Foreground="#FF9FB0C8" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="2" Text="{Binding DurationSeconds, Converter={StaticResource DurationToTextConverter}}" Foreground="#FF82DCC4" FontWeight="SemiBold" HorizontalAlignment="Right" VerticalAlignment="Center" />
                            </Grid></Border>
                        </DataTemplate></ItemsControl.ItemTemplate></ItemsControl>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
